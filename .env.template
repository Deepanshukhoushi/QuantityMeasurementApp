# =========================================================================
# Quantity Measurement App - Unified Environment Variables
# =========================================================================

# --- Database Configuration ---
DB_USERNAME=root
DB_PASSWORD=Deepanshu
DB_WAIT_TIMEOUT=60

# --- Service Discovery ---
EUREKA_SERVER_URL=http://qm-eureka-server:8761/eureka/

# --- External Access Configuration ---
# Replace <EC2_PUBLIC_IP> with your actual EC2 IP or Domain
EC2_PUBLIC_IP=localhost
GATEWAY_URL=http://${EC2_PUBLIC_IP}:8080
FRONTEND_URL=http://${EC2_PUBLIC_IP}:4200

# --- Security & OAuth2 ---
# Google OAuth Credentials (Mandatory for Login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Redirect URIs (Must match Google Cloud Console)
APP_OAUTH2_GOOGLE_REDIRECT_URI=${GATEWAY_URL}/login/oauth2/code/google
APP_OAUTH2_REDIRECT_URI=${FRONTEND_URL}/login
APP_OAUTH2_FAILURE_REDIRECT_URI=${FRONTEND_URL}/login?error=auth_failed
APP_RESET_PASSWORD_URL=${FRONTEND_URL}/reset-password

# JWT Secret (Min 32 chars recommended)
APP_AUTH_TOKEN_SECRET=YourSuperSecretKeyForJWTAuthMin32CharsLong123!
APP_AUTH_TOKEN_EXPIRATION_MSEC=864000000

# --- Mail Configuration (For Password Reset) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# --- Spring Boot Admin ---
SPRING_BOOT_ADMIN_SERVER_URL=http://qm-admin-server:9090
SPRING_PROFILES_ACTIVE=prod
JPA_DDL_AUTO=update
